[*.cs]

# CS8604: Possível argumento de referência nula.
dotnet_diagnostic.CS8604.severity = none

# CS8602: Desreferência de uma referência possivelmente nula.
dotnet_diagnostic.CS8602.severity = none

# CS8619: A anulabilidade de tipos de referência no valor não corresponde ao tipo de destino.
dotnet_diagnostic.CS8619.severity = none

# CS8603: Possível retorno de referência nula.
dotnet_diagnostic.CS8603.severity = none

# CS8629: O tipo de valor de nulidade pode ser nulo.
dotnet_diagnostic.CS8629.severity = none
