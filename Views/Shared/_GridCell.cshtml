@model GridCellViewModel
@using AutoGestao.Models
@using AutoGestao.Extensions

@{
    var itemType = Model.Item.GetType();
    var propertyInfo = itemType.GetProperty(Model.Column.Name);
    var value = propertyInfo?.GetValue(Model.Item);
}

@switch (Model.Column.Type)
{
    case GridColumnType.Actions:
        @if (Model.Actions != null && Model.Actions.Any())
        {
            // Filtrar ações baseado na ShowCondition
            var visibleActions = Model.Actions.Where(action => action.ShowCondition == null || action.ShowCondition(Model.Item)).ToList();
            @if (visibleActions.Any())
            {
                <div class="dropdown">
                    <button class="btn-actions dropdown-toggle" data-bs-toggle="dropdown">
                        Ações
                    </button>
                    <ul class="dropdown-menu">
                        @foreach (var action in visibleActions)
                        {
                            var itemId = itemType.GetProperty("Id")?.GetValue(Model.Item)?.ToString();
                            var actionUrl = action.Url?.Replace("{id}", itemId);

                            <li>
                                <a class="dropdown-item" href="@actionUrl">
                                    <i class="@action.Icon"></i> @action.DisplayName
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
            else
            {
                <div class="d-flex gap-2">
                    <a href="@Url.Action("Details", new { id = itemType.GetProperty("Id")?.GetValue(Model.Item) })"
                       class="icon-button" title="Visualizar">
                        <i class="fas fa-eye"></i>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="d-flex gap-2">
                <a href="@Url.Action("Details", new { id = itemType.GetProperty("Id")?.GetValue(Model.Item) })"
                   class="icon-button" title="Visualizar">
                    <i class="fas fa-eye"></i>
                </a>
            </div>
        }
        break;

    case GridColumnType.Badge:
        @if (Model.Column.Name.ToLower().Contains("ativo"))
        {
            var isActive = Convert.ToBoolean(value ?? false);
            <span class="status-badge @(isActive ? "status-active" : "status-inactive")">
                <i class="fas @(isActive ? "fa-check" : "fa-times")"></i>
                @(isActive ? "Ativo" : "Inativo")
            </span>
        }
        else if (Model.Column.Name.ToLower().Contains("tipo"))
        {
            var displayText = value?.ToString();
            if (value is Enum enumValue)
            {
                displayText = enumValue.GetCategory() ?? enumValue.GetDescription();
            }
            <span class="person-type">@displayText</span>
        }
        else
        {
            try
            {
                var displayText = value?.ToString();
                if (value is Enum enumValue)
                {
                    displayText = enumValue.GetCategory() ?? enumValue.GetDescription();
                }
                <span class="person-type">@displayText</span>
            }
            catch
            {
                @value   
            }
        }
        break;

    case GridColumnType.Currency:
        @if (value != null && decimal.TryParse(value.ToString(), out decimal currencyValue))
        {
            @currencyValue.ToString("C")
        }
        else
        {
            <span class="text-muted">-</span>
        }
        break;

    case GridColumnType.Date:
        @if (value != null && DateTime.TryParse(value.ToString(), out DateTime dateValue))
        {
            @dateValue.ToString("dd/MM/yyyy")
        }
        else
        {
            <span class="text-muted">-</span>
        }
        break;

    case GridColumnType.Number:
        @if (value != null && decimal.TryParse(value.ToString(), out decimal numberValue))
        {
            @numberValue.ToString("N0")
        }
        else
        {
            <span class="text-muted">-</span>
        }
        break;

    case GridColumnType.Integer:
        @if (value != null && long.TryParse(value.ToString(), out long integerValue))
        {
            @integerValue.ToString()
        }
        else
        {
            <span class="text-muted">-</span>
        }
        break;

    case GridColumnType.Boolean:
        @if (value != null && bool.TryParse(value.ToString(), out bool boolValue))
        {
            <span class="status-badge @(boolValue ? "status-active" : "status-inactive")">
                <i class="fas @(boolValue ? "fa-check" : "fa-times")"></i>
                @(boolValue ? "Sim" : "Não")
            </span>
        }
        else
        {
            <span class="text-muted">-</span>
        }
        break;

    case GridColumnType.Custom:
        @if (Model.Column.CustomRender != null)
        {
            @Html.Raw(Model.Column.CustomRender(Model.Item))
        }
        else
        {
            @(value ?? "-")
        }
        break;

    default:
        @if (Model.Column.Name.ToLower() == "nome")
        {
            <a href="@Url.Action("Details", new { id = itemType.GetProperty("Id")?.GetValue(Model.Item) })"
               class="text-decoration-none text-primary fw-medium">
                @value
            </a>
        }
        else
        {
            @(value ?? "-")
        }
        break;
}